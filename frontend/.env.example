# =============================================================================
# Tourism Energy Intelligence — Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values.
# All variables without NEXT_PUBLIC_ prefix are server-only
# and never exposed to the browser.

# ── Backend API ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Tourism Energy Intelligence

# ── Authentication ───────────────────────────────────────────────────────────
# JWT secret for signing auth tokens (change in production)
AUTH_SECRET=change-me-in-production

# ── Open-Meteo Weather API ───────────────────────────────────────────────────
# Free, no API key required. URL can be overridden for self-hosted instances.
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast

# ── ENTSO-E Transparency Platform ────────────────────────────────────────────
# Register at https://transparency.entsoe.eu to get an API key.
ENTSOE_API_KEY=
ENTSOE_BASE_URL=https://web-api.tp.entsoe.eu/api

# ── Electricity Maps ─────────────────────────────────────────────────────────
# Get a free token at https://www.electricitymaps.com
ELECTRICITY_MAPS_TOKEN=
ELECTRICITY_MAPS_BASE_URL=https://api.electricitymap.org/v3

# ── OpenAQ Air Quality ───────────────────────────────────────────────────────
# Free tier, key is optional for basic access
OPENAQ_API_KEY=
OPENAQ_BASE_URL=https://api.openaq.org/v2

# ── Eurostat Tourism Data ────────────────────────────────────────────────────
# Free API with public access
EUROSTAT_API_KEY=
EUROSTAT_BASE_URL=https://ec.europa.eu/eurostat/api/dissemination/statistics/1.0/data

# ── GDACS Disaster Alerts ────────────────────────────────────────────────────
# Free RSS feed, no key required
GDACS_RSS_URL=https://www.gdacs.org/xml/rss_24h.xml

# ── PostgreSQL Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tei
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=tei
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# ── Node Environment ─────────────────────────────────────────────────────────
NODE_ENV=development
