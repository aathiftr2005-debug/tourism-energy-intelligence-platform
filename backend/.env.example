# App
APP_NAME=Tourism Energy Intelligence
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000

# Supabase
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Weather API (OpenWeatherMap)
WEATHER_API_KEY=your_weather_api_key

# Eurostat API (optional base URL)
EUROSTAT_BASE_URL=https://ec.europa.eu/eurostat/api/dissemination/statistics/1.0

# ML Model Path
MODEL_PATH=/app/models

# ETL Settings
ETL_CACHE_MAX_AGE_HOURS=24

# SendGrid (email alerts)
SENDGRID_API_KEY=your_sendgrid_api_key
ALERT_RECIPIENT_EMAIL=your_email@example.com

# Google Gemini (LLM explanations)
GEMINI_API_KEY=your_gemini_api_key
