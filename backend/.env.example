# ============================================================================
# Tourism Energy Intelligence — Backend Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================================

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=Tourism Energy Intelligence
APP_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=false

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=2
LOG_LEVEL=info
REQUEST_TIMEOUT=120

# ── CORS (comma-separated origins) ──────────────────────────────────────────
CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000

# ── Supabase (REQUIRED) ──────────────────────────────────────────────────────
# Use the SERVICE ROLE key (not the anon key) for backend operations
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key

# ── Google Gemini AI (REQUIRED for AI assistant) ─────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── SendGrid Email (optional — alerts won't send without it) ────────────────
SENDGRID_API_KEY=your_sendgrid_api_key
ALERT_RECIPIENT_EMAIL=alerts@yourdomain.com

# ── Weather API (optional — uses Open-Meteo free tier by default) ───────────
WEATHER_API_KEY=

# ── Eurostat (optional — uses public endpoint by default) ───────────────────
EUROSTAT_BASE_URL=https://ec.europa.eu/eurostat/api/dissemination/statistics/1.0

# ── ML Model Storage ────────────────────────────────────────────────────────
MODEL_PATH=/app/app/ml/saved_models

# ── ETL Settings ────────────────────────────────────────────────────────────
ETL_CACHE_MAX_AGE_HOURS=24
